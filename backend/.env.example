# Copy this file to ".env" and adjust values as needed:
#   cp .env.example .env
# The real .env is git-ignored so secrets never get committed.

# Where MongoDB lives.
MONGO_URL=mongodb://localhost:27017

# Database name inside MongoDB.
DB_NAME=farm_app

# Frontend address allowed through CORS.
FRONTEND_URL=http://localhost:5173

# SQLite database file path (created automatically on first run).
SQLITE_URL=sqlite+aiosqlite:///./data/app.db
